generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String    @id @default(uuid())
  email      String    @unique
  name       String?
  image      String?
  role       String    @default("USER") // USER, ADMIN
  gender     String?                    // MALE, FEMALE, OTHER
  city       String?
  hometown   String?
  occupation String?
  mobile     String?
  dob        String?                    // YYYY-MM-DD
  instagram  String?
  createdAt  DateTime  @default(now())
  bookings   Booking[]
  reviews    Review[]
  logs       ActionLog[]
}

model Event {
  id                   String    @id @default(uuid())
  title                String
  description          String
  date                 DateTime
  price                Float     @default(1500)
  femaleDiscount       Float     @default(0)
  genderPricingEnabled Boolean   @default(true)
  minCapacity          Int       @default(10)
  maxCapacity          Int       @default(20)
  status               String    @default("PENDING") // PENDING, CONFIRMED, CANCELLED
  createdAt            DateTime  @default(now())
  bookings             Booking[]
}

model Booking {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId           String
  event             Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  razorpayOrderId   String   @unique
  razorpayPaymentId String?  @unique
  razorpaySignature String?
  status            String   @default("PENDING") // PENDING, CONFIRMED, REFUNDED
  createdAt         DateTime @default(now())
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String
  createdAt DateTime @default(now())
}

// Tracks key user actions for analytics and audit trail
model ActionLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String   // e.g. LOGIN, BOOKING_CREATED, BOOKING_CONFIRMED, PROFILE_UPDATED
  metadata  String?  // JSON string with extra context
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
}
